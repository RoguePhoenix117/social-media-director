# --- Core ---------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:55432/social_media_director
POSTGRES_HOST_PORT=55432
SESSION_SECRET=replace-with-a-random-secret
APP_ENCRYPTION_KEY=replace-with-another-random-secret
# Public URL of this instance. Use 127.0.0.1 (not localhost) for local dev — X's
# developer console rejects localhost for Callback URI / Website URL.
APP_ORIGIN=http://127.0.0.1:5173

# --- Setup security -----------------------------------------------------
# Optional on localhost, REQUIRED before exposing /setup on a public host.
# See docs/developer-oauth-setup.md "Step 4 — Set INSTANCE_SETUP_KEY".
INSTANCE_SETUP_KEY=

# --- OAuth app credentials ----------------------------------------------
# Stored in this file only — never in Postgres. The Setup Mode wizard and
# Settings → Developers merge updates into these lines without touching the
# rest of the file. CLI: pnpm oauth:env -- --x-client-id=...
#
# Register apps following docs/developer-oauth-setup.md.
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- AI -----------------------------------------------------------------
# Operator-scoped fallback for the OpenAI backend. Operators can also
# paste a key into Settings → AI generation; that DB-stored value
# overrides this env var per-operator.
OPENAI_API_KEY=
